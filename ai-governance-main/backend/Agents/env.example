GENAI_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/text-embedding-004
GOOGLE_APPLICATION_CREDENTIALS="./service.json"

GCS_BUCKET=""
GCS_PREFIX="trust-center-docs" # Optional: a folder within the bucket, e.g., "documents/"

RAG_COLLECTION=rag_docs
RAG_TOP_K=4
    
QDRANT_PATH=D:/Agent/data
BACKGROUND_DIR=D:/Agent/background_docs
BACKGROUND_WATCH=1
BACKGROUND_DEBOUNCE_MS=800

ALLOW_GENERAL=1          # 1 = enable general model fallback; 0 = RAG-only
GENERAL_MODE=hybrid      # hybrid | rag | general   (default = hybrid)
MONGODB_URI=
MONGODB_DB=AI-Governance
MONGODB_UPLOADS_COL=rag_uploads
MONGODB_CHATS_COL=rag_chats

GOOGLE_APPLICATION_CREDENTIALS=./service.json
GOOGLE_CLOUD_PROJECT_ID=
GCS_BUCKET_NAME=

QDRANT_PATH=
QDRANT_API_KEY=

# Atlassian Integrations
ATLASSIAN_URL=https://yoursite.atlassian.net
ATLASSIAN_EMAIL=your_email@example.com
ATLASSIAN_API_TOKEN=your_atlassian_api_token

